generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  stores    Store[]
  sessions  Session[]
  accounts  Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Store {
  id          String      @id @default(cuid())
  userId      String
  name        String
  marketplace Marketplace
  apiKey      String
  isActive    Boolean     @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]
  orders      Order[]
  syncLogs    SyncLog[]
  adSpends    AdSpend[]
  orderStats  OrderStat[]

  @@index([userId])
}

enum Marketplace {
  WB
  OZON
}

model Product {
  id             String          @id @default(cuid())
  storeId        String
  externalId     String
  name           String
  category       String?
  brand          String?
  group          String?
  cogsPerUnit    Float           @default(0)
  minMarginPct   Float           @default(15)
  maxDrrPct      Float           @default(15)
  imageUrl       String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders         Order[]
  stockSnapshots StockSnapshot[]
  adSpends       AdSpend[]
  orderStats     OrderStat[]

  @@unique([storeId, externalId])
  @@index([storeId])
}

model Order {
  id            String   @id @default(cuid())
  storeId       String
  productId     String?
  externalId    String?
  date          DateTime
  revenue       Float    @default(0)
  commission    Float    @default(0)
  logistics     Float    @default(0)
  storage       Float    @default(0)
  advertising   Float    @default(0)
  returns       Float    @default(0)
  penalties     Float    @default(0)
  compensations Float    @default(0)
  cogs          Float    @default(0)
  tax           Float    @default(0)
  quantity      Int      @default(1)
  isReturn      Boolean  @default(false)
  createdAt     DateTime @default(now())
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id])

  @@index([storeId, date])
  @@index([productId])
}

model StockSnapshot {
  id        String   @id @default(cuid())
  productId String
  date      DateTime @default(now())
  quantity  Int      @default(0)
  location  String   @default("MP")
  size      String   @default("")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, date])
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model AdSpend {
  id           String         @id @default(cuid())
  storeId      String
  productId    String?
  date         DateTime
  campaignId   String         @default("")
  campaignName String         @default("")
  campaignType String         @default("")
  status       CampaignStatus @default(ACTIVE)
  endDate      DateTime?
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  spend        Float    @default(0)
  ordersCount  Int      @default(0)
  revenue      Float    @default(0)
  createdAt    DateTime @default(now())
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id])

  @@index([storeId, date])
  @@index([productId])
}

model OrderStat {
  id        String   @id @default(cuid())
  storeId   String
  productId String?
  date      DateTime
  ordered   Int      @default(0)  // заказано (все статусы)
  bought    Int      @default(0)  // выкуплено
  cancelled Int      @default(0)  // отменено / не выкуплено
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  @@index([storeId, date])
  @@index([productId])
}

model SyncLog {
  id       String     @id @default(cuid())
  storeId  String
  status   SyncStatus
  message  String?
  syncedAt DateTime   @default(now())
  store    Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILED
}
